{
  "schemaVersion": 1,
  "contract": "calligraphy.artwork.v1",
  "description": "User artwork draft, export, and audit baseline.",
  "artworkDraft": {
    "required": [
      "artwork_id",
      "owner_user_id",
      "text",
      "layout",
      "created_at"
    ],
    "fields": {
      "artwork_id": "Stable draft identifier.",
      "owner_user_id": "Nebula Identity user id.",
      "text": "Original user text.",
      "layout": "Embedded calligraphy.layout.v1 result.",
      "glyph_overrides": "User-selected replacements for specific slots.",
      "exports": "PNG/PDF export records.",
      "created_at": "Creation timestamp.",
      "updated_at": "Last update timestamp."
    }
  },
  "createArtworkDraftRequest": {
    "required": [
      "owner_user_id",
      "layout"
    ],
    "fields": {
      "owner_user_id": "Nebula Identity user id. MVP accepts explicit value until Identity middleware is wired.",
      "layout": "calligraphy.layout.v1 request used to generate the saved draft.",
      "glyph_overrides": "Optional slot-to-glyph replacement map."
    }
  },
  "exportRecord": {
    "fields": {
      "export_id": "Export identifier.",
      "artwork_id": "Artwork draft identifier.",
      "format": "svg, png, or pdf. MVP supports svg.",
      "template_type": "tracing, outline, reference, or share.",
      "content_type": "Rendered artifact content type.",
      "storage_key": "Object storage key.",
      "sha256": "Export artifact checksum.",
      "byte_size": "Artifact byte size.",
      "inline_content": "MVP-only inline artifact content. Production exports should use storage_key.",
      "created_at": "Export timestamp."
    }
  }
}
