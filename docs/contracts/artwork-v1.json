{
  "schemaVersion": 1,
  "contract": "calligraphy.artwork.v1",
  "description": "User artwork draft, export, and audit baseline.",
  "artworkDraft": {
    "required": [
      "artwork_id",
      "owner_user_id",
      "text",
      "layout",
      "created_at"
    ],
    "fields": {
      "artwork_id": "Stable draft identifier.",
      "owner_user_id": "Nebula Identity user id.",
      "text": "Original user text.",
      "layout": "Embedded calligraphy.layout.v1 result.",
      "glyph_overrides": "User-selected replacements for specific slots.",
      "exports": "PNG/PDF export records.",
      "created_at": "Creation timestamp.",
      "updated_at": "Last update timestamp."
    }
  },
  "exportRecord": {
    "fields": {
      "export_id": "Export identifier.",
      "format": "png or pdf.",
      "template_type": "tracing, outline, reference, or share.",
      "storage_key": "Object storage key.",
      "sha256": "Export artifact checksum.",
      "created_at": "Export timestamp."
    }
  }
}

